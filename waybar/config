{
"layer": "top",
"position": "top",
"height": 10,
"margin-bottom":0,
"margin-top":0,

"modules-left": ["network"],
"modules-center": ["hyprland/workspaces"],
"modules-right":  ["tray","pulseaudio","battery","clock"],

"battery": {
  "states": {
  "warning": 30,
  "critical": 15
  },
  "format": "{icon}&#8239;{capacity}%",
  "format-charging": "пГІ&#8239;{capacity}%",
  "format-plugged": "пГІ&#8239;{capacity}%",
  "format-alt": "{icon} {time}",
  "format-icons": ["пХє", "пХЇ", "пХї", "пХЉ", "пХљ", "пХЊ", "пХЄ"],
  "tooltip": false
},
"hyprland/workspaces": {
     "sort-by-name": true,
     "on-click": "activate"
},
"hyprland/window": {
    "max-length": 200,
    "separate-outputs": true
},
"tray": {
    "icon-size": 16,
    "spacing": 6
},
"clock": {
    "locale": "C", 
    "format": "пАЧ {:%H:%M}",
    "format-alt": "пБ≥ {:%a, %b %d, %Y}", // Icon: calendar-alt
    "tooltip": false
},
"network": {
  "interval": 2,
  "format-wifi": "пЗЂ {signalStrength}%",
  "format-ethernet": "пГБ",
  "format-linked": " {ipaddr}",
  "format-disconnected": "пБ± Disconnected",
  "format-disabled": "",
  "tooltip": false,
  "max-length": 20,
  "min-length": 6,
  "format-alt": "{essid}",
},
"pulseaudio": {
  // "scroll-step": 1, // %, can be a float
  "format": "{icon} {volume}% {format_source}",
  "format-bluetooth": "{icon}пКФ {volume}% {format_source}",
  "format-bluetooth-muted": "пС¶ {format_source}",
  "format-muted": "пС¶  {format_source}",
  "format-source": "пД∞ {volume}%",
  "format-source-muted": "пД±",
  "format-icons": {
    "headphone": "пА•",
    "hands-free": "пЦР",
    "headset": "рЯОІ",
    "phone": "пВХ",
    "portable": "пВХ",
    "car": "пЖє",
    "default": ["пА¶", "пАІ", "пА®"]
  },
  "on-click": "pavucontrol",
  "tooltip": false
},
"custom/recorder": {
    "format": "пАљ Rec",
    "format-disabled": "пАљ Off-air", //An empty format will hide the module.
    "return-type": "json",
    "interval": 1,
    "exec": "echo '{\"class\": \"recording\"}'",
    "exec-if": "pgrep wf-recorder",
},
"custom/audiorec": {
    "format": "вЩђ Rec",
    "format-disabled": "вЩђ Off-air", //An empty format will hide the module.
    "return-type": "json",
    "interval": 1,
    "exec": "echo '{\"class\": \"audio recording\"}'",
    "exec-if": "pgrep ffmpeg",
},
}
